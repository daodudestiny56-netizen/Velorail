# Telegram Bot API Token obtained from @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Google Gemini Developer API Key from Google AI Studio
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: OpenAI API Key for live voice transcription via Whisper API
OPENAI_API_KEY=your_openai_api_key_here

# Fallback text returned by the voice processor when Whisper is skipped
MOCK_TRANSCRIPTION_TEXT=Transfer 250 USD to Alice for groceries

# Maximum allowed duration of a voice message in seconds
MAX_VOICE_SECONDS=30

# EVM Somnia Testnet Node RPC URL
EVM_RPC_URL=https://api.infra.testnet.somnia.network

# EVM Bot Wallet Private Key (Use a dedicated test wallet, never a personal mainnet key)
BOT_PRIVATE_KEY=your_dedicated_test_bot_private_key_here

# EVM Somnia Testnet Block Explorer transaction prefix
BLOCK_EXPLORER_URL=https://explorer-testnet.somnia.network/tx/
